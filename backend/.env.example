# Application
APP_NAME=Community API
APP_VERSION=1.0.0
DEBUG=True

# Database - PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/app

# JWT
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
FRONTEND_URL=http://localhost:5173

# Super Admin (최초 슈퍼 관리자 계정 — 서버 시작 시 자동 생성)
# 아래 4개를 모두 설정해야 생성됩니다. 생성 후 비밀번호는 변경하세요.
SUPER_ADMIN_USERNAME=super
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=1111
SUPER_ADMIN_NICKNAME=관리자
